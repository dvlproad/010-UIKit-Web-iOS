CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
EMBEDDED_CONTENT_CONTAINS_SWIFT = YES
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseHelper" "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit" "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit-Swift" "${PODS_CONFIGURATION_BUILD_DIR}/CJFile" "${PODS_CONFIGURATION_BUILD_DIR}/CJWebKit" "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit" "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoResource" "${PODS_CONFIGURATION_BUILD_DIR}/Masonry" "${PODS_CONFIGURATION_BUILD_DIR}/SVProgressHUD" "${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_Web" "${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_Web-Swift"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseHelper/CJBaseHelper.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit-Swift/CJBaseUIKit_Swift.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit/CJBaseUIKit.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CJFile/CJFile.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CJWebKit/CJWebKit.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit/CQDemoKit.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoResource/CQDemoResource.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/Masonry/Masonry.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/SVProgressHUD/SVProgressHUD.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_Web-Swift/TSDemo_Web_Swift.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_Web/TSDemo_Web.framework/Headers"
LD_RUNPATH_SEARCH_PATHS = $(inherited) /usr/lib/swift '@executable_path/Frameworks' '@loader_path/Frameworks'
LIBRARY_SEARCH_PATHS = $(inherited) "${TOOLCHAIN_DIR}/usr/lib/swift/${PLATFORM_NAME}" /usr/lib/swift
OTHER_CFLAGS = $(inherited) -isystem "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseHelper/CJBaseHelper.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit-Swift/CJBaseUIKit_Swift.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit/CJBaseUIKit.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/CJFile/CJFile.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/CJWebKit/CJWebKit.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit/CQDemoKit.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoResource/CQDemoResource.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/Masonry/Masonry.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/SVProgressHUD/SVProgressHUD.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_Web/TSDemo_Web.framework/Headers" -isystem "${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_Web-Swift/TSDemo_Web_Swift.framework/Headers" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseHelper" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit-Swift" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/CJFile" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/CJWebKit" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoResource" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/Masonry" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/SVProgressHUD" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_Web" -iframework "${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_Web-Swift"
OTHER_LDFLAGS = $(inherited) -framework "CJBaseHelper" -framework "CJBaseUIKit" -framework "CJBaseUIKit_Swift" -framework "CJFile" -framework "CJWebKit" -framework "CQDemoKit" -framework "CQDemoResource" -framework "Foundation" -framework "Masonry" -framework "QuartzCore" -framework "SVProgressHUD" -framework "TSDemo_Web" -framework "TSDemo_Web_Swift" -framework "UIKit" -framework "WebKit"
OTHER_MODULE_VERIFIER_FLAGS = $(inherited) "-F${PODS_CONFIGURATION_BUILD_DIR}/CJBaseHelper" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit-Swift" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJFile" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJWebKit" "-F${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit" "-F${PODS_CONFIGURATION_BUILD_DIR}/CQDemoResource" "-F${PODS_CONFIGURATION_BUILD_DIR}/Masonry" "-F${PODS_CONFIGURATION_BUILD_DIR}/SVProgressHUD" "-F${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_Web" "-F${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_Web-Swift"
OTHER_SWIFT_FLAGS = $(inherited) -D COCOAPODS
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
